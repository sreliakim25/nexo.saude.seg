# ============================================================
# NEXO · SAÚDE & SANEAMENTO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git
# ============================================================

# ─── SUPABASE ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── UPSTASH REDIS (cache) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=https://SEU_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ─── MODO DE DADOS ─────────────────────────────────────────
# false = usar dados mock (desenvolvimento)
# true  = usar APIs e banco real (produção)
USE_REAL_DATA=false

# ─── DATASUS (somente se USE_REAL_DATA=true) ───────────────
# Requer cadastro em datasus.saude.gov.br e cadastro de IP
# DATASUS_API_USER=seu_login_datasus
# DATASUS_API_TOKEN=seu_token_datasus

# ─── PORTAL DA TRANSPARÊNCIA (somente se USE_REAL_DATA=true)
# Registro gratuito em portaldatransparencia.gov.br/api-de-dados
# TRANSPARENCIA_API_KEY=sua_chave_api

# ─── APP ───────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Nexo
NEXT_PUBLIC_VERSION=0.1.0

# ─── MUNICÍPIO PILOTO ──────────────────────────────────────
NEXT_PUBLIC_MUNICIPIO_PILOTO=2611606
NEXT_PUBLIC_UF_PILOTO=PE
